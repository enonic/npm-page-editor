{
  "name": "@enonic/page-editor",
  "version": "0.0.7-SNAPSHOT",
  "description": "Adds page editing capability for externally rendered sites in Enonic XP",
  "license": "GPL-3.0",
  "author": "Pavel Milkevich <pmi@enonic.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/enonic/npm-page-editor.git"
  },
  "bugs": {
    "url": "https://github.com/enonic/npm-page-editor/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/enonic/npm-page-editor#readme",
  "keywords": [
    "enonic",
    "xp",
    "content studio",
    "page editor",
    "cms",
    "content management system"
  ],
  "type": "module",
  "main": "index.cjs",
  "module": "index.js",
  "types": "index.d.ts",
  "sideEffects": [
    "*.css"
  ],
  "engines": {
    "node": ">= 24.13.0"
  },
  "scripts": {
    "build": "pnpm build:dev",
    "build:prod": "pnpm --color /^build:prod:.*$/",
    "build:prod:js": "cross-env BUILD_TARGET=js vite build --mode production",
    "build:prod:css": "cross-env BUILD_TARGET=css vite build --mode production",
    "build:dev": "pnpm --color /^build:dev:.*$/",
    "build:dev:js": "cross-env BUILD_TARGET=js vite build --mode development",
    "build:dev:css": "cross-env BUILD_TARGET=css vite build --mode development",
    "check": "pnpm /^check:.*$/",
    "check:types": "tsc --build --noEmit",
    "check:lint": "eslint . --quiet --cache",
    "check:v2:lint": "oxlint src/main/resources/assets/js/v2/ .storybook/page-editor/ .storybook/v2/",
    "check:v2:fmt": "oxfmt --check src/main/resources/assets/js/v2/ .storybook/page-editor/ .storybook/v2/",
    "check:test": "vitest run",
    "fix": "eslint --fix **/*.ts",
    "fix:v2": "oxlint --fix src/main/resources/assets/js/v2/ .storybook/page-editor/ .storybook/v2/ && oxfmt src/main/resources/assets/js/v2/ .storybook/page-editor/ .storybook/v2/",
    "clean": "del-cli build/ enonic-page-editor-*.zip",
    "test": "vitest run",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "src/main/resources/assets/js/v2/**/*.{ts,tsx}": [
      "oxlint --fix",
      "oxfmt"
    ],
    ".storybook/page-editor/**/*.{ts,tsx}": [
      "oxlint --fix",
      "oxfmt"
    ],
    ".storybook/v2/**/*.{ts,tsx}": [
      "oxlint --fix",
      "oxfmt"
    ]
  },
  "files": [
    "dist",
    "LICENSE.txt",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./fonts/*": "./dist/fonts/*",
    "./styles.css": "./dist/main.css"
  },
  "dependencies": {
    "nanostores": "^1.2.0"
  },
  "devDependencies": {
    "@enonic/eslint-config": "^2.1.0",
    "@enonic/ui": "^0.47.10",
    "@eslint/js": "^9.39.2",
    "@storybook/addon-docs": "~10.2.19",
    "@storybook/addon-themes": "~10.2.19",
    "@storybook/preact-vite": "~10.2.19",
    "@tailwindcss/vite": "~4.2.1",
    "@types/node": "^25.0.10",
    "browserslist-config-enonic": "^1.0.8",
    "cross-env": "^10.0.0",
    "del-cli": "^7.0.0",
    "enonic-admin-artifacts": "^2.3.2",
    "eslint": "^9.33.0",
    "globals": "^16.3.0",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.4.0",
    "lucide-preact": "^1.8.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "oxlint-tsgolint": "^0.21.0",
    "preact": "^10.29.0",
    "simple-git-hooks": "^2.13.1",
    "storybook": "~10.2.19",
    "tailwindcss": "~4.2.1",
    "tw-animate-css": "~1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2",
    "vite-plugin-dts": "^4.4.0",
    "vitest": "^3.2.4"
  }
}
