{
    "name": "@enonic/page-editor",
    "version": "2.0.0-alpha.1",
    "description": "Adds page editing capability for externally rendered sites in Enonic XP",
    "license": "GPL-3.0",
    "author": "Pavel Milkevich <pmi@enonic.com>",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/enonic/npm-page-editor.git"
    },
    "bugs": {
        "url": "https://github.com/enonic/npm-page-editor/issues"
    },
    "publishConfig": {
        "access": "public"
    },
    "homepage": "https://github.com/enonic/npm-page-editor#readme",
    "keywords": [
        "enonic",
        "xp",
        "content studio",
        "page editor",
        "cms",
        "content management system"
    ],
    "type": "module",
    "main": "dist/index.cjs",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "sideEffects": [
        "*.css"
    ],
    "packageManager": "pnpm@11.4.0",
    "engines": {
        "node": ">= 24.16.0",
        "pnpm": ">= 11.4.0"
    },
    "scripts": {
        "build": "pnpm clean && pnpm build:prod",
        "build:prod": "vp build --mode production",
        "build:dev": "vp build --mode development",
        "build:storybook": "storybook build",
        "build:all": "pnpm build && pnpm build:storybook",
        "dev": "storybook dev -p 6006",
        "clean": "rm -rf dist build coverage reports storybook-static",
        "check": "vp check && tsgo --build --noEmit",
        "check:fix": "vp check --fix && tsgo --build --noEmit",
        "typecheck": "tsgo --build --noEmit",
        "lint": "vp lint",
        "lint:fix": "vp lint --fix",
        "format": "vp fmt",
        "format:check": "vp fmt --check",
        "test": "vp test run",
        "test:watch": "vp test",
        "size": "size-limit",
        "analyze": "pnpm build && open reports/stats.html",
        "prepublishOnly": "pnpm check && pnpm test && pnpm build && pnpm size",
        "release:dry": "pnpm publish --dry-run --no-git-checks",
        "prepare": "vp config"
    },
    "files": [
        "dist",
        "LICENSE.txt",
        "README.md"
    ],
    "exports": {
        ".": {
            "node": {
                "types": "./dist/index.ssr.d.ts",
                "import": "./dist/index.ssr.js",
                "require": "./dist/index.ssr.cjs"
            },
            "workerd": {
                "types": "./dist/index.ssr.d.ts",
                "import": "./dist/index.ssr.js",
                "require": "./dist/index.ssr.cjs"
            },
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./protocol": {
            "types": "./dist/protocol.d.ts",
            "import": "./dist/protocol.js",
            "require": "./dist/protocol.cjs"
        }
    },
    "dependencies": {
        "nanostores": "^1.4.0"
    },
    "devDependencies": {
        "@enonic/ui": "~1.0.5",
        "@microsoft/api-extractor": "^7.58.9",
        "@preact/preset-vite": "~2.10.5",
        "@size-limit/preset-small-lib": "~12.1.0",
        "@storybook/addon-docs": "~10.4.6",
        "@storybook/addon-themes": "~10.4.6",
        "@storybook/preact-vite": "~10.4.6",
        "@tailwindcss/vite": "~4.3.2",
        "@types/node": "~25.9.4",
        "@typescript/native-preview": "7.0.0-dev.20260614.1",
        "jsdom": "^29.1.1",
        "lucide-preact": "^1.23.0",
        "preact": "^10.29.4",
        "rollup-plugin-visualizer": "~7.0.1",
        "size-limit": "~12.1.0",
        "storybook": "~10.4.6",
        "tailwindcss": "~4.3.2",
        "terser": "~5.48.0",
        "tw-animate-css": "~1.4.0",
        "typescript": "^6.0.3",
        "vite": "catalog:",
        "vite-plugin-dts": "~5.0.3",
        "vite-plus": "catalog:"
    },
    "size-limit": [
        {
            "path": "dist/index.js",
            "limit": "700 KB"
        },
        {
            "path": "dist/index.cjs",
            "limit": "700 KB"
        },
        {
            "path": "dist/protocol.js",
            "limit": "5 KB"
        }
    ]
}
