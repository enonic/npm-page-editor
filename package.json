{
  "name": "@enonic/page-editor",
  "version": "0.0.7-SNAPSHOT",
  "description": "Adds page editing capability for externally rendered sites in Enonic XP",
  "license": "GPL-3.0",
  "author": "Pavel Milkevich <pmi@enonic.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/enonic/npm-page-editor.git"
  },
  "bugs": {
    "url": "https://github.com/enonic/npm-page-editor/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/enonic/npm-page-editor#readme",
  "keywords": [
    "enonic",
    "xp",
    "content studio",
    "page editor",
    "cms",
    "content management system"
  ],
  "type": "module",
  "main": "index.cjs",
  "module": "index.js",
  "types": "index.d.ts",
  "sideEffects": [
    "*.css"
  ],
  "engines": {
    "node": ">= 24.15.0"
  },
  "scripts": {
    "build": "pnpm build:dev",
    "build:prod": "vite build --mode production",
    "build:dev": "vite build --mode development",
    "check": "pnpm /^check:.*$/",
    "check:types": "tsc --noEmit",
    "check:lint": "eslint . --quiet --cache",
    "check:test": "vitest run",
    "fix": "eslint --fix **/*.ts",
    "clean": "rm -rf build/ enonic-page-editor-*.zip",
    "test": "vitest run",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "files": [
    "dist",
    "LICENSE.txt",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "dependencies": {
    "jquery": "~3.7.1",
    "jquery-simulate": "^1.0.2",
    "jquery-ui": "^1.14.1",
    "nanoid": "^5.1.7",
    "nanostores": "^1.3.0",
    "q": "^1.5.1"
  },
  "devDependencies": {
    "@enonic/eslint-config": "^2.1.0",
    "dompurify": "^3.4.0",
    "@enonic/lib-admin-ui": "file:.xp/dev/lib-admin-ui",
    "@enonic/lib-contentstudio": "file:.xp/dev/lib-contentstudio",
    "@enonic/ui": "^0.48.0",
    "@eslint/js": "^9.39.2",
    "@rollup/plugin-inject": "^5.0.5",
    "@storybook/addon-docs": "~10.3.5",
    "@storybook/addon-themes": "~10.3.5",
    "@storybook/preact-vite": "~10.3.5",
    "@tailwindcss/vite": "~4.2.1",
    "@types/jquery": "^3.5.33",
    "@types/jqueryui": "^1.12.24",
    "@types/node": "^25.0.10",
    "eslint": "^9.33.0",
    "globals": "^16.3.0",
    "jsdom": "^26.1.0",
    "lucide-preact": "^1.8.0",
    "mousetrap": "^1.6.5",
    "preact": "^10.29.1",
    "storybook": "~10.3.5",
    "tailwindcss": "~4.2.1",
    "tw-animate-css": "~1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2",
    "vite-plugin-dts": "^4.4.0",
    "vitest": "^3.2.4"
  }
}
