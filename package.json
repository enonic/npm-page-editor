{
  "name": "@enonic/page-editor",
  "version": "0.0.7-SNAPSHOT",
  "description": "Adds page editing capability for externally rendered sites in Enonic XP",
  "license": "GPL-3.0",
  "author": "Pavel Milkevich <pmi@enonic.com>",
  "contributors": [
    "Mikita Taukachou <edloidas@gmail.com>"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/enonic/npm-page-editor.git"
  },
  "bugs": {
    "url": "https://github.com/enonic/npm-page-editor/issues"
  },
  "homepage": "https://github.com/enonic/npm-page-editor#readme",
  "keywords": [
    "enonic",
    "xp",
    "content studio",
    "page editor",
    "cms",
    "content management system"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "engines": {
    "node": ">= 24.15.0"
  },
  "files": [
    "dist",
    "LICENSE.txt",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/main.css"
  },
  "scripts": {
    "build": "vp run clean && vp build",
    "build:storybook": "storybook build",
    "check": "vp check",
    "clean": "rm -rf dist coverage reports storybook-static *.tgz",
    "fix": "vp check --fix && pnpm typecheck",
    "pack:inspect": "pnpm pack && tar -tzf enonic-page-editor-*.tgz && rm enonic-page-editor-*.tgz",
    "prepare": "vp config",
    "prepublishOnly": "pnpm check && pnpm typecheck && pnpm build",
    "publish:dry": "pnpm publish --dry-run --no-git-checks --tag beta",
    "storybook": "storybook dev -p 6006",
    "test": "vp test --run",
    "typecheck": "tsgo --noEmit"
  },
  "devDependencies": {
    "@enonic/ui": "^0.47.10",
    "@preact/preset-vite": "~2.10.5",
    "@storybook/addon-docs": "~10.3.5",
    "@storybook/addon-themes": "~10.3.5",
    "@storybook/preact-vite": "~10.3.5",
    "@tailwindcss/vite": "~4.2.2",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260416.1",
    "jsdom": "^29.0.2",
    "lucide-preact": "^1.8.0",
    "nanostores": "^1.2.0",
    "preact": "^10.29.1",
    "storybook": "~10.3.5",
    "tailwindcss": "~4.2.2",
    "tw-animate-css": "~1.4.0",
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.18",
    "vite-plugin-dts": "^4.5.4",
    "vite-plus": "catalog:",
    "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.18"
  },
  "packageManager": "pnpm@10.33.0"
}
