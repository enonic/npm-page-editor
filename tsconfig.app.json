{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist/types",
    "rootDir": "src",
    "declaration": true,
    "sourceMap": true,
    "removeComments": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "paths": {
      "react": ["./node_modules/preact/compat/src/index.d.ts"],
      "react-dom": ["./node_modules/preact/compat/src/index.d.ts"],
      "react/jsx-runtime": ["./node_modules/preact/jsx-runtime/src/index.d.ts"],
      "react/jsx-dev-runtime": ["./node_modules/preact/jsx-runtime/src/index.d.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "build", "**/*.test.ts", "**/*.test.tsx"]
}
