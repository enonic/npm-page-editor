{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": ".",
    "outDir": "build/storybook"
  },
  "include": [
    "src/main/resources/assets/js/types.d.ts",
    ".storybook/stories/**/*",
    "src/main/resources/assets/js/v2/**/*"
  ],
  "exclude": [
